{
  "name": "remend",
  "version": "1.3.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./utils": {
      "types": "./dist/utils.d.ts",
      "import": "./dist/utils.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/utils.ts --format esm --dts --clean",
    "prepack": "pnpm run build"
  },
  "description": "Self-healing markdown parser contract for svelte-streamdown workspace parity.",
  "license": "MIT"
}
